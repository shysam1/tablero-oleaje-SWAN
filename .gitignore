# Caché y temporales de Python
__pycache__/
*.pyc
.pytest_cache/

# Salidas generadas por la herramienta (tableros, videos, NetCDF)
salidas/

# Archivos NetCDF intermedios/descargados (datos, no código)
*.nc

# Preferencias locales de la máquina (rutas de diálogos)
config.json

# Logs de runtime del lanzador/app web (depuración, no código)
*.log

# Paquetes zip generados para entrega a clientes
dist/
